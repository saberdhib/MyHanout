# =============================================================================
# MyHanout AI — Exemple de configuration. Copier en `.env` et adapter.
# AUCUNE valeur réelle ici : ce fichier est versionné.
# =============================================================================

# --- Général ---------------------------------------------------------------
ENV=local                       # local | staging | production
DEBUG=true
LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR
SECRET_KEY=change-me-super-secret-key

# --- Auth / JWT ------------------------------------------------------------
# Le secret de signature JWT réutilise SECRET_KEY. À changer hors local.
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
# Mots de passe des comptes de démo créés par le seed (admin + merchant).
SEED_ADMIN_PASSWORD=admin
SEED_MERCHANT_PASSWORD=merchant

# --- API -------------------------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120
# Observabilité / tracing
OTEL_ENABLED=false
SERVICE_NAME=myhanout-api
# RAG
RAG_VECTOR_STORE=memory          # memory | pgvector
EMBEDDING_PROVIDER=mock          # mock | mistral
RAG_TOP_K=4
API_HOST=0.0.0.0
API_PORT=8000
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Base de données (PostgreSQL 16 + pgvector) ----------------------------
POSTGRES_USER=myhanout
POSTGRES_PASSWORD=myhanout
POSTGRES_DB=myhanout
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# URL async (asyncpg). Construite à partir des variables ci-dessus si vide.
DATABASE_URL=postgresql+asyncpg://myhanout:myhanout@postgres:5432/myhanout

# --- Redis / Celery --------------------------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- OCR provider ----------------------------------------------------------
OCR_PROVIDER=mock               # mock | mistral | pdf_fallback
MISTRAL_API_KEY=sk-fake-mistral-key

# --- LLM provider ----------------------------------------------------------
LLM_PROVIDER=mock               # mock | claude | mistral | huggingface
ANTHROPIC_API_KEY=sk-ant-fake-key
LLM_MODEL=claude-opus-4-8

# --- HuggingFace (LLM + embeddings + images via Inference API) -------------
# Mets ta clé HF ici puis LLM_PROVIDER=huggingface / EMBEDDING_PROVIDER=huggingface
# et/ou IMAGE_PROVIDER=huggingface pour générer les affiches promo.
HUGGINGFACE_API_KEY=
HF_LLM_MODEL=mistralai/Mistral-7B-Instruct-v0.3
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
HF_IMAGE_MODEL=stabilityai/stable-diffusion-xl-base-1.0

# --- Génération de visuels (affiches promo, text-to-image) -----------------
IMAGE_PROVIDER=mock             # mock | huggingface

# --- Import factures par email (IMAP) --------------------------------------
EMAIL_PROVIDER=mock             # mock | imap
EMAIL_IMAP_HOST=
EMAIL_IMAP_PORT=993
EMAIL_IMAP_USER=
EMAIL_IMAP_PASSWORD=
EMAIL_IMAP_FOLDER=INBOX

# --- Entrepôt de données (DWH) / export ------------------------------------
DWH_TARGET=mock                 # mock | http
DWH_URL=

# --- Capteurs de température (chaîne du froid) ------------------------------
SENSOR_PROVIDER=mock            # mock | http (passerelle thermomètres connectés)
SENSOR_HTTP_URL=

# --- Connecteur caisse (POS) -----------------------------------------------
POS_CONNECTOR=mock              # mock | http (caisse réelle)
POS_URL=

# --- Telegram (Bot API) ----------------------------------------------------
TELEGRAM_PROVIDER=mock          # mock | bot
TELEGRAM_BOT_TOKEN=
# Secret d'en-tête pour vérifier les webhooks Telegram (vide = pas de vérif).
TELEGRAM_WEBHOOK_SECRET=

# --- Forecasting -----------------------------------------------------------
FORECAST_MODEL=naive            # naive | prophet | lgbm
FORECAST_HORIZON_DAYS=14

# --- WhatsApp Business API -------------------------------------------------
WHATSAPP_PROVIDER=mock          # mock | business
WHATSAPP_PHONE_NUMBER_ID=000000000000000
WHATSAPP_ACCESS_TOKEN=fake-whatsapp-token
WHATSAPP_VERIFY_TOKEN=local-verify-token
# Secret d'app Meta pour vérifier la signature des webhooks (vide = pas de vérif).
WHATSAPP_APP_SECRET=
GRAPH_API_VERSION=v20.0

# --- Frontend --------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8000/api/v1
# Identifiants de démo utilisés par le dashboard pour le login auto (dev).
VITE_DEMO_EMAIL=admin@myhanout.example
VITE_DEMO_PASSWORD=admin

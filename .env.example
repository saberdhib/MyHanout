# =============================================================================
# MyHanout AI — Exemple de configuration. Copier en `.env` et adapter.
# AUCUNE valeur réelle ici : ce fichier est versionné.
# =============================================================================

# --- Général ---------------------------------------------------------------
ENV=local                       # local | staging | production
DEBUG=true
LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR
SECRET_KEY=change-me-super-secret-key

# --- API -------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Base de données (PostgreSQL 16 + pgvector) ----------------------------
POSTGRES_USER=myhanout
POSTGRES_PASSWORD=myhanout
POSTGRES_DB=myhanout
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# URL async (asyncpg). Construite à partir des variables ci-dessus si vide.
DATABASE_URL=postgresql+asyncpg://myhanout:myhanout@postgres:5432/myhanout

# --- Redis / Celery --------------------------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- OCR provider ----------------------------------------------------------
OCR_PROVIDER=mock               # mock | mistral | pdf_fallback
MISTRAL_API_KEY=sk-fake-mistral-key

# --- LLM provider ----------------------------------------------------------
LLM_PROVIDER=mock               # mock | mistral | claude
ANTHROPIC_API_KEY=sk-ant-fake-key
LLM_MODEL=claude-opus-4-8

# --- Forecasting -----------------------------------------------------------
FORECAST_MODEL=naive            # naive | prophet | lgbm
FORECAST_HORIZON_DAYS=14

# --- WhatsApp Business API -------------------------------------------------
WHATSAPP_PROVIDER=mock          # mock | business_api
WHATSAPP_PHONE_NUMBER_ID=000000000000000
WHATSAPP_ACCESS_TOKEN=fake-whatsapp-token
WHATSAPP_VERIFY_TOKEN=local-verify-token

# --- Frontend --------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8000/api/v1

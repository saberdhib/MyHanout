---
import Base from "../layouts/Base.astro";
import { SITE } from "../consts";

const pillars = [
  {
    id: "human",
    title: "Human-in-the-loop",
    body: "L'IA propose, vous disposez. Aucune commande fournisseur, aucun message client, aucune publication ne part sans votre validation explicite. Chaque action est tracée dans un journal d'audit.",
    points: ["Statuts brouillon → validé", "Journal d'audit horodaté", "Vous gardez toujours la main"],
  },
  {
    id: "rgpd",
    title: "RGPD par conception",
    body: "Le strict nécessaire, et rien d'autre. Les clients ne sont contactés que s'ils ont donné leur consentement (opt-in). Par défaut, aucune donnée ne part chez un tiers : traitement local et fournisseurs mockés.",
    points: ["Consentement opt-in obligatoire", "Minimisation des données", "Aucun tiers par défaut"],
  },
  {
    id: "tenant",
    title: "Isolation multi-commerce",
    body: "Chaque commerce est cloisonné par un garde-fou central : un commerce ne peut jamais voir les données d'un autre. L'identité du commerce vient du jeton d'authentification, jamais d'un paramètre falsifiable.",
    points: ["Filtrage automatique par commerce", "Issu du token, non falsifiable", "Testé (isolation A ≠ B)"],
  },
  {
    id: "explicable",
    title: "Explicabilité",
    body: "Pas de boîte noire. Chaque prévision, suggestion de réassort et promo porte sa justification : demande, stock, délai fournisseur, météo, tendance. Vous comprenez toujours le « pourquoi ».",
    points: ["Justification sur chaque suggestion", "Sources des signaux affichées", "Décisions auditables"],
  },
  {
    id: "keyless",
    title: "Keyless par défaut",
    body: "L'outil fonctionne et se démontre sans aucune clé API : tout est mockable. Vous branchez vos propres clés (HuggingFace, WhatsApp…) quand vous le décidez, via votre configuration.",
    points: ["Démo sans dépendance externe", "Vos clés, votre config", "Souveraineté technique"],
  },
  {
    id: "souverain",
    title: "Canal léger",
    body: "WhatsApp et Telegram suffisent : pas d'app lourde à installer, pas de matériel, pas de collecte tierce imposée. L'IA s'adapte au commerçant, pas l'inverse.",
    points: ["Zéro installation", "Photo de facture = ingestion", "Adapté au terrain"],
  },
];
---

<Base title={`Confiance & RGPD — ${SITE.name}`} description="Human-in-the-loop, RGPD par conception, isolation multi-commerce et explicabilité. Notre engagement de confiance.">
  <section class="relative overflow-hidden">
    <div class="pointer-events-none absolute inset-0 -z-10">
      <div class="absolute -top-24 right-0 h-80 w-80 rounded-full bg-brand/15 blur-[120px]"></div>
    </div>
    <div class="container-x pt-20 pb-12 text-center sm:pt-24">
      <span class="eyebrow reveal">Confiance & RGPD</span>
      <h1 class="reveal mx-auto mt-5 max-w-3xl text-4xl font-extrabold tracking-tight text-night sm:text-5xl">
        Une IA au service du commerçant, pas de la donnée
      </h1>
      <p class="reveal mx-auto mt-5 max-w-2xl text-lg text-night-700">
        La confiance n'est pas une option qu'on coche. C'est une exigence d'architecture,
        présente dans chaque ligne de code.
      </p>
    </div>
  </section>

  <section class="container-x pb-24">
    <div class="grid gap-5 md:grid-cols-2">
      {
        pillars.map((p) => (
          <article id={p.id} class="reveal card scroll-mt-24">
            <h2 class="text-xl font-bold text-night">{p.title}</h2>
            <p class="mt-3 leading-relaxed text-night-700">{p.body}</p>
            <ul class="mt-5 flex flex-wrap gap-2">
              {p.points.map((pt) => (
                <li class="rounded-full bg-brand-50 px-3 py-1 text-xs font-semibold text-brand-dark">{pt}</li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </section>

  <section class="bg-night text-center text-white">
    <div class="container-x py-20">
      <h2 class="reveal mx-auto max-w-2xl text-3xl font-extrabold tracking-tight sm:text-4xl">
        « On ne stocke rien chez des tiers. »
      </h2>
      <p class="reveal mx-auto mt-4 max-w-xl text-white/70">
        Par défaut, traitement local et providers mockés. Vous décidez de chaque intégration externe.
      </p>
      <a href="/contact" class="btn-primary reveal mt-8">Poser vos questions de conformité</a>
    </div>
  </section>
</Base>

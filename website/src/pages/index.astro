---
import Base from "../layouts/Base.astro";
import BrowserFrame from "../components/BrowserFrame.astro";
import ScrollSyncShowcase from "../components/ScrollSyncShowcase.astro";
import { SITE } from "../consts";

const features = [
  {
    title: "Factures sans saisie",
    body: "OCR des factures (photo, PDF, email). L'IA pré-remplit n°, date, fournisseur, montant — vous validez en un clic. Suivi payé / non payé.",
    icon: "doc",
    span: "lg:col-span-3",
  },
  {
    title: "Réassort explicable",
    body: "Des suggestions de commande justifiées : demande prévue + stock + délai fournisseur + météo. Jamais une boîte noire.",
    icon: "cart",
    span: "lg:col-span-3",
  },
  {
    title: "Communication depuis votre téléphone",
    body: "Répondez, animez votre clientèle et publiez vos offres depuis WhatsApp, Telegram & Slack. L'IA rédige, génère l'affiche, et publie après votre validation.",
    icon: "chat",
    span: "lg:col-span-2",
  },
  {
    title: "Demande client & approvisionnement",
    body: "Anticipez les pics (week-end, fêtes, météo) ET ce qu'il faut commander. Modèles naïf → Prophet/LightGBM, écart prévu/réel suivi.",
    icon: "chart",
    span: "lg:col-span-2",
  },
  {
    title: "Dépendances entre produits",
    body: "Comprenez ce qui se vend ensemble (compléments) ou se reporte en cas de rupture (substituts) — pour prévoir juste, pas produit par produit.",
    icon: "spark",
    span: "lg:col-span-2",
  },
  {
    title: "Gestion financière",
    body: "Charges classées OPEX/CAPEX, trésorerie avec alerte cash, valorisation du stock et marges réelles — de la pré-compta explicable.",
    icon: "euro",
    span: "lg:col-span-2",
  },
  {
    title: "Sur WhatsApp & Telegram",
    body: "Tout se pilote par message. Pas d'app lourde à installer. Une photo de facture suffit.",
    icon: "chat",
    span: "lg:col-span-2",
  },
];

const steps = [
  {
    n: "01",
    title: "Connectez votre commerce",
    body: "Inscription en 2 minutes. Importez votre catalogue (photo, email, JSON, caisse) — ou partez de zéro.",
  },
  {
    n: "02",
    title: "Laissez l'IA travailler",
    body: "Factures lues, demande et approvisionnement prévus, dépendances entre produits détectées, messages prêts. Chaque proposition est expliquée.",
  },
  {
    n: "03",
    title: "Vous validez, c'est tout",
    body: "Aucune action sortante sans votre accord. Vous gardez la main ; l'IA fait le travail ingrat.",
  },
];

function icon(name: string) {
  const common = 'fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"';
  switch (name) {
    case "doc":
      return `<svg viewBox="0 0 24 24" ${common}><path d="M14 3v4a1 1 0 0 0 1 1h4"/><path d="M17 21H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h7l5 5v11a2 2 0 0 1-2 2Z"/><path d="M9 13h6M9 17h4"/></svg>`;
    case "cart":
      return `<svg viewBox="0 0 24 24" ${common}><circle cx="9" cy="20" r="1"/><circle cx="18" cy="20" r="1"/><path d="M2 3h2l2.4 12.4a2 2 0 0 0 2 1.6h7.7a2 2 0 0 0 2-1.6L21 7H5.6"/></svg>`;
    case "spark":
      return `<svg viewBox="0 0 24 24" ${common}><path d="M12 3v4M12 17v4M5 12H1M23 12h-4M6.3 6.3 8.5 8.5M15.5 15.5l2.2 2.2M17.7 6.3l-2.2 2.2M8.5 15.5l-2.2 2.2"/></svg>`;
    case "chart":
      return `<svg viewBox="0 0 24 24" ${common}><path d="M3 3v18h18"/><path d="m7 14 3-4 4 3 5-7"/></svg>`;
    case "chat":
      return `<svg viewBox="0 0 24 24" ${common}><path d="M21 11.5a8.5 8.5 0 0 1-12.3 7.6L3 21l1.9-5.7A8.5 8.5 0 1 1 21 11.5Z"/></svg>`;
    case "euro":
      return `<svg viewBox="0 0 24 24" ${common}><path d="M15 7a5 5 0 1 0 0 10M4 10h6M4 14h5"/></svg>`;
    default:
      return "";
  }
}
---

<Base>
  <!-- ===================== HERO ===================== -->
  <section class="relative overflow-hidden">
    <!-- halos décoratifs -->
    <div class="pointer-events-none absolute inset-0 -z-10">
      <div class="absolute -top-32 right-[-10%] h-[420px] w-[420px] rounded-full bg-brand/20 blur-[120px]"></div>
      <div class="absolute top-40 left-[-10%] h-[360px] w-[360px] rounded-full bg-accent/10 blur-[120px]"></div>
    </div>

    <div class="container-x pt-20 pb-16 text-center sm:pt-28">
      <span class="eyebrow reveal">🇲🇦 🇫🇷 Copilote des commerces de proximité</span>
      <h1 class="reveal mx-auto mt-6 max-w-4xl text-4xl font-extrabold leading-[1.08] tracking-tight text-night sm:text-6xl">
        L'IA qui gère la paperasse,<br class="hidden sm:block" />
        <span class="bg-gradient-to-r from-brand to-brand-dark bg-clip-text text-transparent">
          vous gardez votre commerce.
        </span>
      </h1>
      <p class="reveal mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-night-700">
        Anticipez votre <strong>demande client</strong> et votre <strong>approvisionnement</strong>,
        comprenez les <strong>dépendances entre vos produits</strong>, et
        <strong>pilotez &amp; communiquez depuis votre téléphone</strong> (WhatsApp, Telegram, Slack).
        Vos factures sont lues automatiquement — sans saisie, sans jargon, sans boîte noire.
      </p>
      <div class="reveal mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a href={`${SITE.appUrl}/signup`} class="btn-primary px-6 py-3.5 text-base">
          Essayer gratuitement
        </a>
        <a href="/contact" class="btn-ghost px-6 py-3.5 text-base">Demander une démo</a>
      </div>
      <p class="reveal mt-4 text-sm text-night-700/60">
        Sans carte bancaire · Démo fonctionnelle en mode bac à sable
      </p>

      <!-- Capture produit réelle -->
      <div class="reveal relative mt-16">
        <div class="absolute inset-x-10 -bottom-6 -z-10 h-40 rounded-full bg-brand/30 blur-3xl"></div>
        <BrowserFrame
          src="/shots/dashboard.png"
          alt="Tableau de bord MyHanout AI : stocks, alertes, signaux du jour"
          class="mx-auto max-w-4xl"
        />
      </div>
    </div>
  </section>

  <!-- ============ SCROLL-SYNC : ce que MyHanout fait pour vous ============ -->
  <ScrollSyncShowcase />

  <!-- ===================== BANDEAU CONFIANCE ===================== -->
  <section class="border-y border-night/[0.06] bg-surface/60">
    <div class="container-x grid grid-cols-2 gap-6 py-8 text-center md:grid-cols-4">
      {
        [
          ["100%", "explicable"],
          ["0", "saisie de facture"],
          ["RGPD", "par conception"],
          ["WhatsApp", "& Telegram"],
        ].map(([big, small]) => (
          <div class="reveal">
            <div class="text-2xl font-extrabold text-night">{big}</div>
            <div class="text-sm text-night-700/70">{small}</div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- ===================== POUR VOTRE MÉTIER (verticaux) ===================== -->
  <section class="container-x py-24">
    <div class="mx-auto max-w-2xl text-center">
      <span class="eyebrow reveal">Pour votre métier</span>
      <h2 class="reveal mt-5 text-3xl font-extrabold tracking-tight text-night sm:text-4xl">
        Pensé pour les commerces alimentaires de proximité
      </h2>
      <p class="reveal mt-4 text-night-700/70">
        Un socle commun, adapté à votre métier : la navigation et les agents s'ajustent
        automatiquement à votre type de commerce.
      </p>
    </div>
    <div class="reveal mt-12 grid grid-cols-2 gap-5 lg:grid-cols-4">
      {
        [
          ["boucherie", "Boucherie", "Lots, découpe, rendement, traçabilité"],
          ["boulangerie", "Boulangerie", "Production du jour, recettes, fournées"],
          ["primeur", "Primeur", "Frais, démarque anti-gaspi, DLC"],
          ["epicerie", "Épicerie", "Réassort, marges, prix conseillés"],
        ].map(([slug, title, desc]) => (
          <article class="group overflow-hidden rounded-2xl border border-night/[0.06] bg-white shadow-sm transition-shadow hover:shadow-md">
            <img
              src={`/verticals/${slug}.png`}
              alt={`MyHanout AI pour ${title}`}
              width="800"
              height="800"
              loading="lazy"
              class="aspect-square w-full object-cover"
            />
            <div class="p-4">
              <h3 class="font-bold text-night">{title}</h3>
              <p class="mt-1 text-sm text-night-700/70">{desc}</p>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <!-- ===================== FONCTIONS (bento) ===================== -->
  <section id="fonctions" class="container-x scroll-mt-24 py-24">
    <div class="mx-auto max-w-2xl text-center">
      <span class="eyebrow reveal">Ce que ça fait</span>
      <h2 class="reveal mt-5 text-3xl font-extrabold tracking-tight text-night sm:text-4xl">
        Tout le back-office, en pilote automatique
      </h2>
      <p class="reveal mt-4 text-lg text-night-700">
        Chaque suggestion est justifiée. Chaque action sortante passe par vous.
      </p>
    </div>

    <div class="mt-14 grid gap-5 lg:grid-cols-6">
      {
        features.map((f) => (
          <article class={`reveal card group flex flex-col ${f.span}`}>
            <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-brand-50 text-brand-dark transition-colors group-hover:bg-brand group-hover:text-white">
              <span class="h-6 w-6" set:html={icon(f.icon)} />
            </div>
            <h3 class="mt-5 text-lg font-bold text-night">{f.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-night-700">{f.body}</p>
          </article>
        ))
      }
    </div>
  </section>

  <!-- ===================== PROMOS (split visuel) ===================== -->
  <section class="bg-night text-surface">
    <div class="container-x grid items-center gap-12 py-24 lg:grid-cols-2">
      <div>
        <span class="eyebrow reveal border-white/15 bg-white/5 text-brand-light">Communication</span>
        <h2 class="reveal mt-5 text-3xl font-extrabold tracking-tight sm:text-4xl">
          Gardez la relation client dans votre poche
        </h2>
        <p class="reveal mt-4 text-lg leading-relaxed text-white/70">
          L'IA rédige vos messages et vos offres, <strong class="text-white">génère l'affiche</strong>
          et publie après votre validation — sur <strong class="text-white">WhatsApp, Telegram &amp; Slack</strong>,
          vos réseaux et vos clients consentants (RGPD). Vous animez votre commerce depuis votre téléphone.
        </p>
        <ul class="reveal mt-7 space-y-3">
          {
            [
              "Messages + affiches générés automatiquement",
              "WhatsApp / Telegram / Slack + réseaux + clients opt-in",
              "Publication validée par vous, tracée (audit)",
            ].map((t) => (
              <li class="flex items-start gap-3 text-white/80">
                <span class="mt-0.5 flex h-5 w-5 flex-none items-center justify-center rounded-full bg-brand text-white text-xs">✓</span>
                {t}
              </li>
            ))
          }
        </ul>
        <a href={`${SITE.appUrl}/promos`} class="btn-primary reveal mt-8">Voir les promos en action</a>
      </div>
      <div class="reveal">
        <BrowserFrame src="/shots/promos.png" alt="Promo flash générée avec affiche et aperçu WhatsApp" url="app.myhanout.ai/promos" />
      </div>
    </div>
  </section>

  <!-- ===================== FINANCE (split visuel) ===================== -->
  <section class="container-x py-24">
    <div class="grid items-center gap-12 lg:grid-cols-2">
      <div class="reveal order-2 lg:order-1">
        <BrowserFrame
          src="/shots/finance.png"
          alt="Page Finance : trésorerie, marges et classification OPEX/CAPEX"
          url="app.myhanout.ai/finance"
        />
      </div>
      <div class="order-1 lg:order-2">
        <span class="eyebrow reveal">Gestion financière</span>
        <h2 class="reveal mt-5 text-3xl font-extrabold tracking-tight text-night sm:text-4xl">
          Vos factures deviennent du pilotage
        </h2>
        <p class="reveal mt-4 text-lg leading-relaxed text-night-700">
          La donnée déjà saisie travaille pour vous : charges classées
          <strong> OPEX / CAPEX</strong> (validées par vous), trésorerie estimée avec
          <strong> alerte cash</strong>, valeur du stock et <strong>marges réelles</strong> par produit.
        </p>
        <ul class="reveal mt-7 space-y-3">
          {
            [
              "Catégorisation IA expliquée, corrigée en un clic",
              "Alerte trésorerie + échéances à venir",
              "Marge réelle & signal de coût d'achat en hausse",
            ].map((t) => (
              <li class="flex items-start gap-3 text-night-700">
                <span class="mt-0.5 flex h-5 w-5 flex-none items-center justify-center rounded-full bg-brand text-white text-xs">✓</span>
                {t}
              </li>
            ))
          }
        </ul>
        <p class="reveal mt-6 text-sm text-night-700/60">
          Pré-compta / pilotage — pas de comptabilité certifiée.
        </p>
      </div>
    </div>
  </section>

  <!-- ===================== COMMENT ÇA MARCHE ===================== -->
  <section class="container-x py-24">
    <div class="mx-auto max-w-2xl text-center">
      <span class="eyebrow reveal">Comment ça marche</span>
      <h2 class="reveal mt-5 text-3xl font-extrabold tracking-tight text-night sm:text-4xl">
        Opérationnel en une après-midi
      </h2>
    </div>
    <div class="mt-14 grid gap-6 md:grid-cols-3">
      {
        steps.map((s) => (
          <div class="reveal card relative">
            <span class="text-sm font-extrabold text-brand">{s.n}</span>
            <h3 class="mt-2 text-lg font-bold text-night">{s.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-night-700">{s.body}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- ===================== COMMENT ON OPÈRE (archi + accompagnement) ===================== -->
  <section class="bg-night text-surface">
    <div class="container-x py-24">
      <div class="mx-auto max-w-2xl text-center">
        <span class="eyebrow reveal border-white/15 bg-white/5 text-brand-light">Comment on opère</span>
        <h2 class="reveal mt-5 text-3xl font-extrabold tracking-tight sm:text-4xl">
          On se plugge, on lance la machine, vous validez
        </h2>
        <p class="reveal mt-4 text-lg leading-relaxed text-white/70">
          Vos données entrent telles quelles, notre moteur travaille, les décisions
          reviennent sur vos canaux du quotidien. Vous gardez la main de bout en bout.
        </p>
      </div>

      <!-- Schéma d'architecture (léger, sobre) -->
      <div class="reveal mt-14 flex flex-col items-stretch gap-4 lg:flex-row lg:items-center">
        <div class="flex-1 rounded-xl2 border border-white/10 bg-white/5 p-5">
          <div class="text-xs font-semibold uppercase tracking-wide text-brand-light">Vos sources</div>
          <ul class="mt-3 space-y-2 text-sm text-white/85">
            <li>Caisse (POS)</li>
            <li>Factures (photo / email)</li>
            <li>Stock &amp; ventes</li>
            <li>Signaux (météo, événements…)</li>
          </ul>
        </div>

        <div class="self-center text-2xl text-brand-light rotate-90 lg:rotate-0" aria-hidden="true">→</div>

        <div class="flex-1 rounded-xl2 border border-brand/40 bg-brand/10 p-5 shadow-card">
          <div class="text-xs font-semibold uppercase tracking-wide text-brand-light">
            Le moteur MyHanout <span class="text-accent">✦</span>
          </div>
          <ul class="mt-3 space-y-2 text-sm text-white">
            <li>Prévision demande &amp; approvisionnement</li>
            <li>Dépendances entre produits</li>
            <li>Alertes intelligentes</li>
            <li>Messages &amp; offres prêts</li>
          </ul>
        </div>

        <div class="self-center text-2xl text-brand-light rotate-90 lg:rotate-0" aria-hidden="true">→</div>

        <div class="flex-1 rounded-xl2 border border-white/10 bg-white/5 p-5">
          <div class="text-xs font-semibold uppercase tracking-wide text-brand-light">Vos canaux</div>
          <ul class="mt-3 space-y-2 text-sm text-white/85">
            <li>Dashboard web / mobile</li>
            <li>WhatsApp</li>
            <li>Telegram</li>
            <li>Slack</li>
          </ul>
        </div>
      </div>
      <p class="reveal mt-4 text-center text-xs text-white/50">
        Multi-tenant, RGPD, human-in-the-loop · aucune action sortante sans votre validation.
      </p>

      <!-- Illustration du flux (données → moteur → canaux) -->
      <img
        src="/illustrations/data-flow.png"
        alt="Flux MyHanout : vos données passent par le moteur puis reviennent sur vos canaux"
        width="1600"
        height="900"
        loading="lazy"
        class="reveal mx-auto mt-12 w-full max-w-4xl rounded-2xl"
      />

      <!-- Ouvert & interopérable -->
      <div class="reveal mt-8 flex flex-wrap items-center justify-center gap-2 text-sm">
        <span class="text-white/60">Ouvert &amp; interopérable :</span>
        {
          ["API ouverte (REST)", "Webhooks", "n8n", "Make", "Zapier", "MCP (agents IA)"].map((t) => (
            <span class="rounded-full border border-white/15 bg-white/5 px-3 py-1 text-white/85">{t}</span>
          ))
        }
      </div>

      <!-- Accompagnement (done-for-you) -->
      <div class="mt-16 grid gap-6 md:grid-cols-4">
        {
          [
            { n: "01", t: "Audit & conseil", b: "On analyse votre commerce, vos données et vos enjeux. Stratégie claire, sans jargon." },
            { n: "02", t: "On se plugge", b: "Caisse, factures, messagerie : branchés en douceur, sans changer vos habitudes." },
            { n: "03", t: "On lance la machine", b: "Prévisions, réassort, dépendances, alertes, communication : l'IA fait le travail." },
            { n: "04", t: "Vous payez aux résultats", b: "Rien ne part sans votre accord. Vous gardez la main, vous mesurez la valeur." },
          ].map((s) => (
            <div class="reveal rounded-xl2 border border-white/10 bg-white/5 p-5">
              <span class="text-sm font-extrabold text-brand-light">{s.n}</span>
              <h3 class="mt-2 text-base font-bold text-white">{s.t}</h3>
              <p class="mt-2 text-sm leading-relaxed text-white/70">{s.b}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===================== CONFIANCE TEASER ===================== -->
  <section class="container-x pb-24 pt-24">
    <div class="reveal overflow-hidden rounded-xl2 border border-night/[0.06] bg-gradient-to-br from-surface to-brand-50 p-10 sm:p-14">
      <div class="grid gap-10 lg:grid-cols-3">
        <div class="lg:col-span-1">
          <h2 class="text-2xl font-extrabold tracking-tight text-night sm:text-3xl">
            Une IA en qui on peut avoir confiance
          </h2>
          <a href="/confiance" class="btn-dark mt-6">Notre engagement →</a>
        </div>
        <div class="grid gap-6 sm:grid-cols-3 lg:col-span-2">
          {
            [
              ["Human-in-the-loop", "Aucune commande, message ou publication sans votre validation."],
              ["RGPD par conception", "Consentement explicite, minimisation, rien chez des tiers par défaut."],
              ["Multi-commerce isolé", "Vos données ne croisent jamais celles d'un autre commerce."],
            ].map(([t, b]) => (
              <div>
                <h3 class="font-bold text-night">{t}</h3>
                <p class="mt-1.5 text-sm leading-relaxed text-night-700">{b}</p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== CTA FINAL ===================== -->
  <section class="relative overflow-hidden bg-night text-center text-white">
    <div class="pointer-events-none absolute inset-0 -z-0">
      <div class="absolute left-1/2 top-0 h-72 w-72 -translate-x-1/2 rounded-full bg-brand/30 blur-[120px]"></div>
    </div>
    <div class="container-x relative py-24">
      <h2 class="reveal mx-auto max-w-2xl text-3xl font-extrabold tracking-tight sm:text-5xl">
        Reprenez votre temps. Confiez-nous la paperasse.
      </h2>
      <p class="reveal mx-auto mt-5 max-w-xl text-lg text-white/70">
        Essayez gratuitement en mode bac à sable — sans clé API, sans carte bancaire.
      </p>
      <div class="reveal mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a href={`${SITE.appUrl}/signup`} class="btn-primary px-6 py-3.5 text-base">Créer mon compte</a>
        <a href="/contact" class="btn px-6 py-3.5 text-base border border-white/20 text-white hover:bg-white/10">
          Parler à un humain
        </a>
      </div>
    </div>
  </section>
</Base>

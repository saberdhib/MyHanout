---
import Base from "../layouts/Base.astro";
import { SITE } from "../consts";

const tiers = [
  {
    name: "Découverte",
    price: "0",
    period: "/ pour toujours",
    tagline: "Pour tester sans risque.",
    cta: "Commencer",
    href: `${SITE.appUrl}/signup`,
    highlighted: false,
    features: [
      "1 commerce",
      "Factures : OCR + validation (jusqu'à 20/mois)",
      "Prévisions & alertes de stock",
      "Assistant WhatsApp (bac à sable)",
      "Mode mock — aucune clé requise",
    ],
  },
  {
    name: "Commerce",
    price: "29",
    period: "€ / mois",
    tagline: "Le quotidien d'un commerce de proximité.",
    cta: "Essayer 14 jours",
    href: `${SITE.appUrl}/signup`,
    highlighted: true,
    features: [
      "Factures illimitées (photo, email, PDF)",
      "Réassort explicable + 3 modes d'envoi",
      "Promos anti-gaspillage + affiches générées",
      "WhatsApp & Telegram réels",
      "Prévisions avancées (Prophet/LightGBM)",
      "Audit complet & RGPD",
    ],
  },
  {
    name: "Multi-boutique",
    price: "Sur mesure",
    period: "",
    tagline: "Plusieurs points de vente, comptable, intégrations.",
    cta: "Nous contacter",
    href: "/contact",
    highlighted: false,
    features: [
      "Plusieurs commerces isolés",
      "Rôles : owner / staff / comptable / lecture",
      "Import JSON & sync entrepôt de données",
      "Connecteurs sur mesure",
      "Accompagnement dédié",
    ],
  },
];

const lifecycle = [
  ["Actif", "Toutes les fonctions IA, promos, WhatsApp, prévisions.", "Abonnement standard"],
  ["Grâce (2-3 mois)", "En cas d'impayé, tout reste actif. Rappels doux.", "Aucune coupure"],
  ["Rétrogradé", "Accès lecture + stockage à petit prix.", "Vous gardez vos données"],
  ["Réactivation", "Paiement différé possible → retour à Actif.", "Sans aucune perte"],
];
---

<Base title={`Tarifs — ${SITE.name}`} description="Une tarification humaine, dégressive et sans coupure brutale. Mode gratuit keyless pour tester.">
  <section class="container-x pt-20 pb-10 text-center sm:pt-24">
    <span class="eyebrow reveal">Tarifs</span>
    <h1 class="reveal mx-auto mt-5 max-w-3xl text-4xl font-extrabold tracking-tight text-night sm:text-5xl">
      Un prix juste, jamais une coupure brutale
    </h1>
    <p class="reveal mx-auto mt-5 max-w-2xl text-lg text-night-700">
      Commencez gratuitement, sans carte bancaire ni clé API. Évoluez quand votre commerce le décide.
    </p>
  </section>

  <section class="container-x pb-16">
    <div class="grid gap-6 lg:grid-cols-3">
      {
        tiers.map((t) => (
          <article
            class={`reveal relative flex flex-col rounded-xl2 border p-8 ${
              t.highlighted
                ? "border-brand bg-night text-white shadow-card"
                : "border-night/[0.08] bg-white shadow-soft"
            }`}
          >
            {t.highlighted && (
              <span class="absolute -top-3 left-8 rounded-full bg-brand px-3 py-1 text-xs font-bold text-white">
                Le plus choisi
              </span>
            )}
            <h3 class={`text-lg font-bold ${t.highlighted ? "text-white" : "text-night"}`}>{t.name}</h3>
            <p class={`mt-1 text-sm ${t.highlighted ? "text-white/60" : "text-night-700/70"}`}>{t.tagline}</p>
            <div class="mt-6 flex items-baseline gap-1">
              <span class={`text-4xl font-extrabold ${t.highlighted ? "text-white" : "text-night"}`}>{t.price}</span>
              <span class={`text-sm ${t.highlighted ? "text-white/60" : "text-night-700/70"}`}>{t.period}</span>
            </div>
            <a
              href={t.href}
              class={`mt-6 ${t.highlighted ? "btn-primary" : "btn-ghost"} w-full`}
            >
              {t.cta}
            </a>
            <ul class="mt-8 space-y-3 text-sm">
              {t.features.map((f) => (
                <li class={`flex items-start gap-2.5 ${t.highlighted ? "text-white/80" : "text-night-700"}`}>
                  <span class="mt-0.5 flex h-5 w-5 flex-none items-center justify-center rounded-full bg-brand/15 text-brand-dark text-xs">✓</span>
                  {f}
                </li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
    <p class="reveal mt-6 text-center text-sm text-night-700/60">
      Prix indicatifs hors période de démo. Sans engagement — résiliable à tout moment.
    </p>
  </section>

  <!-- Engagement humain (cycle de vie sans coupure) -->
  <section class="bg-surface/60 py-20">
    <div class="container-x">
      <div class="mx-auto max-w-2xl text-center">
        <span class="eyebrow reveal">Notre différence</span>
        <h2 class="reveal mt-5 text-3xl font-extrabold tracking-tight text-night">
          Un impayé ne coupe jamais votre outil
        </h2>
        <p class="reveal mt-4 text-night-700">
          Le commerce a des hauts et des bas. Notre tarification est dégressive et humaine :
          vous ne perdez jamais l'accès à vos données.
        </p>
      </div>
      <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {
          lifecycle.map(([t, b, note], i) => (
            <div class="reveal card">
              <div class="text-sm font-extrabold text-brand">{`0${i + 1}`}</div>
              <h3 class="mt-2 font-bold text-night">{t}</h3>
              <p class="mt-1.5 text-sm leading-relaxed text-night-700">{b}</p>
              <p class="mt-3 text-xs font-semibold uppercase tracking-wide text-brand-dark">{note}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="container-x py-20 text-center">
    <h2 class="reveal text-2xl font-extrabold text-night sm:text-3xl">Une question sur l'offre ?</h2>
    <a href="/contact" class="btn-primary reveal mt-6">Parler à un humain</a>
  </section>
</Base>

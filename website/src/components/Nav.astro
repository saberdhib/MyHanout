---
import Logo from "./Logo.astro";
import { NAV, SITE } from "../consts";
const path = Astro.url.pathname;
---

<header
  class="sticky top-0 z-50 border-b border-night/[0.06] bg-white/80 backdrop-blur-xl"
>
  <nav class="container-x flex h-16 items-center justify-between">
    <Logo />

    <div class="hidden items-center gap-1 md:flex">
      {
        NAV.map((item) => {
          const active = item.href === path || (item.href !== "/" && path.startsWith(item.href));
          return (
            <a
              href={item.href}
              class={`rounded-full px-4 py-2 text-sm font-medium transition-colors ${
                active ? "text-brand-dark" : "text-night-700 hover:text-night"
              }`}
            >
              {item.label}
            </a>
          );
        })
      }
    </div>

    <div class="flex items-center gap-2">
      <a href={SITE.appUrl} class="hidden text-sm font-semibold text-night-700 hover:text-night sm:inline-flex px-3 py-2">
        Connexion
      </a>
      <a href={`${SITE.appUrl}/signup`} class="btn-primary text-sm">
        Essayer gratuitement
      </a>
    </div>
  </nav>
</header>
